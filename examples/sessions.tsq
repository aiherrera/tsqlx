@driver postgres

@table sessions

@version 1

@input
  userId string

-- Common read for "active sessions for a user" — tune columns to your auth store.
@query listActiveSessions
  SELECT
    s.id,
    s.user_id,
    s.last_seen_at,
    s.user_agent
  FROM sessions s
  WHERE s.user_id = {userId}::uuid
  AND s.revoked_at IS NULL
  ORDER BY s.last_seen_at DESC
  LIMIT 50

@output
  id string
  user_id string
  last_seen_at Date
  user_agent string
