{
  "name": "@tsqlx/demo",
  "private": true,
  "type": "module",
  "scripts": {
    "codegen": "tsqlx compile --root . --glob \"queries/**/*.tsq\"",
    "prestart": "pnpm run codegen",
    "start": "node --import tsx src/index.ts",
    "dev": "pnpm run codegen && node --import tsx --watch src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@tsqlx/cli": "workspace:*",
    "dotenv": "^17.4.2",
    "hono": "^4.12.16",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
